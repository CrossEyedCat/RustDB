@startuml RustDB Architecture

!define RECTANGLE class

package "Client layer" {
    [CLI Client] as CLI
    [Network Client] as NET
}

package "Network layer" {
    [Network Server] as NS
    [Connection Pool] as CP
}

package "Main server" {
    [Main Server] as MS
    [Session Manager] as SM
}

package "Parser and planner" {
    [SQL Parser] as SP
    [Query Planner] as QP
    [Query Optimizer] as QO
    [AST Builder] as AST
}

package "Query execution" {
    [Query Executor] as QE
    [Operator Tree] as OT
    [Result Set] as RS
}

package "Database core" {
    [Transaction Manager] as TM
    [Lock Manager] as LM
    [Recovery Manager] as RM
    [Buffer Manager] as BM
}

package "Storage" {
    [Page Manager] as PM
    [File Manager] as FM
    [Index Manager] as IM
    [Table Manager] as TBM
}

package "Metadata catalog" {
    [Schema Manager] as SC
    [Statistics Manager] as ST
    [Access Control] as AC
}

package "Physical storage" {
    [Data Files] as DF
    [Index Files] as IF
    [Log Files] as LF
    [System Catalog] as SYSCAT
}

' External interactions
CLI --> NS : SQL
NET --> NS : Network requests

' Network layer
NS --> CP : Connections
CP --> MS : Requests
MS --> SM : Sessions

' Parse and plan
SM --> SP : SQL
SP --> AST : Build AST
AST --> QP : AST
QP --> QO : Plan
QO --> QE : Optimized plan

' Execute
QE --> OT : Operator tree
OT --> QE : Operator results
QE --> RS : Result rows

' Core
QE --> TM : Transaction
TM --> LM : Locks
TM --> RM : WAL
QE --> BM : Pages

' Storage
BM --> PM : Pages
PM --> FM : Files
QE --> IM : Indexes
QE --> TBM : Tables

' Catalog
QP --> SC : Schema
QO --> ST : Statistics
SM --> AC : Permissions

' Physical
FM --> DF : Data file I/O
IM --> IF : Index files
RM --> LF : Log append
SC --> SYSCAT : Catalog

' Responses
RS --> MS : Result
MS --> NS : Response
NS --> CLI : To client

' Core internals
TM --> BM : Buffers
LM --> TM : Lock info
RM --> TM : Recovery state

' Storage internals
PM --> BM : Page updates
TBM --> PM : Page requests
IM --> PM : Index pages

@enduml
